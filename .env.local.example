# Shared secret between Next.js server and FastAPI.
# Generate: openssl rand -hex 32
INTERNAL_API_KEY=replace-me

# Where the Next.js server should reach FastAPI.
# Local dev: go through the Next.js rewrite to uvicorn :8000
INTERNAL_API_URL=http://127.0.0.1:3000

# On Vercel: leave unset. The helper falls back to https://$VERCEL_URL
# so server-to-server calls hit the same deployment.

# Auto-set by Vercel when "Protection Bypass for Automation" is enabled
# (Project Settings → Deployment Protection). Required so server actions on
# protected previews can loop back through the Vercel edge. Leave unset locally.
# VERCEL_AUTOMATION_BYPASS_SECRET=

# Supabase Postgres (use the pooler URL — port 6543 — with sslmode=require).
# Never commit real credentials; set the real value in .env.local and in Vercel env vars.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require
